# Supabase Configuration
# Copy this file to .env and fill in your values
# Do NOT commit .env to version control

# Supabase Project URL (from Supabase dashboard -> Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key (from Supabase dashboard -> Settings -> API)
# Used in mobile app for client-side access
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (from Supabase dashboard -> Settings -> API)
# Used in Edge Functions for admin operations - NEVER use in mobile app
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Firebase Cloud Messaging (FCM)
# Used for push notifications
FCM_SERVER_KEY=your_fcm_server_key_here

# Optional: Database Connection String (for local development/migrations)
# DATABASE_URL=postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres
